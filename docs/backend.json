
{
  "entities": {
    "GradeIndicator": {
      "title": "Indicador de Logro",
      "description": "Criterio de evaluación curricular.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "unidad_id": { "type": "string" },
        "periodo_id": { "type": "string" },
        "codigo": { "type": "string" },
        "descripcion": { "type": "string" },
        "peso_porcentaje": { "type": "number" }
      }
    },
    "Evaluation": {
      "title": "Evaluación / Actividad",
      "description": "Instancia de calificación (Rúbrica, Cotejo, Quizz).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "indicador_id": { "type": "string" },
        "nombre": { "type": "string" },
        "tipo": { "type": "string", "enum": ["manual", "cotejo", "rubrica", "escala", "anecdotario", "grupal", "quizz"] },
        "peso_instrumento": { "type": "number" },
        "configuracion_json": { "type": "object" }
      }
    },
    "EvaluationConfig": {
      "title": "Configuración de Evaluación",
      "description": "Configuración pedagógica de una evaluación, incluyendo criterios e instrumentos digitalizados.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "unidad_id": { "type": "string" },
        "periodo_id": { "type": "string" },
        "nombre": { "type": "string" },
        "tipo_instrumento": { "type": "string" },
        "estrategia": { "type": "string" },
        "criterios": { "type": "array" },
        "indicador_codigo": { "type": "string" },
        "indicador_peso": { "type": "number" },
        "instrumento_peso": { "type": "number" },
        "max_puntos": { "type": "number" },
        "creado_el": { "type": "object" }
      }
    },
    "QuizRoom": {
      "title": "Sala de Quiz (Real-time)",
      "description": "Estado de una sesión de quiz activa en Firebase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "evaluationId": { "type": "string" },
        "status": { "type": "string", "enum": ["lobby", "active", "finished"] },
        "code": { "type": "string" },
        "currentQuestionIndex": { "type": "number" },
        "questions": { "type": "array" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/evaluaciones_config/{evalId}": {
      "schema": "EvaluationConfig",
      "description": "Repositorio de instrumentos digitalizados y configuraciones para gamificación."
    },
    "/quiz_rooms/{roomId}": {
      "schema": "QuizRoom",
      "description": "Salas de quiz activas para interacción en tiempo real."
    },
    "/quiz_rooms/{roomId}/participants/{participantId}": {
      "schema": "object",
      "description": "Estudiantes conectados a la sala de juego."
    }
  }
}
